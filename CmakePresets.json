{
  "version": 5,
  "configurePresets": [
    {
      "name": "vscode",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "vscode-host",
      "inherits": "vscode",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "$env{HOME}/Documents/Libraries/CANSec"
      }
    },
    {
      "name": "vscode-container",
      "inherits": "vscode",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "/host_libraries/CANSec"
      }
    },
    {
      "name": "vscode-tmp",
      "generator": "Ninja",
      "binaryDir": "/tmp/vscode-build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "/host_libraries/CANSec"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vscode",
      "configurePreset": "vscode"
    },
    {
      "name": "vscode-host",
      "configurePreset": "vscode-host"
    },
    {
      "name": "vscode-container",
      "configurePreset": "vscode-container"
    },
    {
      "name": "vscode-tmp",
      "configurePreset": "vscode-tmp"
    }
  ]
}
